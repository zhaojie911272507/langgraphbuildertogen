# LangGraph Gen API（Builder 调用代码生成服务的地址。Docker 部署时应填写 langgraph-gen 容器的地址：http://langgraph-gen:8001/api/generate）
LANGGRAPH_API_URL=http://localhost:8001/api/generate

# MongoDB - dbconnect 模块使用
DB_HOST=127.0.0.1
DB_PORT=27017
DB_USER=admin
DB_PASSWORD=xxxx
DB_AUTHSOURCE=admin
DB_DATABASE=mydatabase
DB_COLLECTION=customers

# MongoDB - langgraphgenpy/mongodbcon 与 dbconnect 共用
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=xxxx
MONGO_AUTH_SOURCE=admin
MONGO_DB_NAME=xxxx
MONGO_SLICE_A=127.0.0.1:27017

# MongoDB 连接池与超时（可选，mongodbcon 使用，有默认值）
# MONGO_MAX_POOL_SIZE=100
# MONGO_MIN_POOL_SIZE=10
# MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGO_CONNECT_TIMEOUT_MS=5000


