# LangGraph Gen - 代码生成后端服务
FROM python:3.12-slim

WORKDIR /app

# 安装依赖
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制项目代码
COPY langgraphgenpy/ ./langgraphgenpy/

# 设置 Python 路径
ENV PYTHONPATH=/app
WORKDIR /app/langgraphgenpy/openapi

EXPOSE 8001

# 生产模式运行，不使用 reload
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8001"]
